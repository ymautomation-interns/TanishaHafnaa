# Postgres connection. Either set DATABASE_URL, or the individual PG* vars below.
DATABASE_URL=postgres://postgres:tanisha%4006@localhost:5433/ym_automation

# Used only if DATABASE_URL is not set
PGHOST=127.0.0.1npm run seed
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=ym_automation

# Port the API server listens on
PORT=4000

# Comma separated list of origins allowed to call the API (your frontend URL(s))
CORS_ORIGIN=http://localhost:5173

# Admin login
ADMIN_USERNAME=admin
# Generate this with: npm run hash-password -- "your-password"
ADMIN_PASSWORD_HASH=

# Any long random string
JWT_SECRET=change-this-to-a-long-random-string
